{
  "name": "@promptctl/tmux-control-mode-js",
  "version": "0.1.0",
  "description": "Node.js client for tmux control mode protocol",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "default": "./dist/protocol/index.js"
    },
    "./terminal": {
      "types": "./dist/terminal/index.d.ts",
      "default": "./dist/terminal/index.js"
    },
    "./keymap": {
      "types": "./dist/keymap/index.d.ts",
      "default": "./dist/keymap/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "workspaces": [
    "examples/web-multiplexer"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "tsc --build --clean",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "TMUX_INTEGRATION=1 vitest run tests/integration/",
    "test:all": "TMUX_INTEGRATION=1 vitest run",
    "demo": "npm --workspace tmux-control-mode-js-demo-web-multiplexer run dev",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --build",
    "check:deps": "node scripts/check-no-deps.mjs",
    "prepublishOnly": "npm run check:deps && npm run build"
  },
  "keywords": [
    "tmux",
    "control-mode",
    "terminal"
  ],
  "author": {
    "name": "Brandon Fryslie",
    "email": "530235+brandon-fryslie@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
